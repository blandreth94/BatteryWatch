# Copy to .env.local and fill in values.
# When set, these are baked into the build at compile time.
# Fields locked by env vars appear read-only in the Settings UI.

# TBA Read API key v3 (get one at thebluealliance.com/account)
VITE_TBA_API_KEY=

# TBA event key (e.g. 2026vapor, 2026cmptx)
VITE_TBA_EVENT_KEY=

# Optional: pre-fill event name and team number
VITE_EVENT_NAME=
VITE_TEAM_NUMBER=
